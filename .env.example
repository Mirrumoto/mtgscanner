# Rename this file to .env and fill in your API keys
GEMINI_API_KEY=your-gemini-key

# Optional: OpenAI-compatible local/remote endpoint serving Gemma (Unsloth, llama.cpp server, vLLM, etc.)
UNSLOTH_BASE_URL=
UNSLOTH_API_KEY=
# Options: gemma4:e2b | gemma4:e4b | gemma4:26b | gemma4:31b
UNSLOTH_VISION_MODEL=gemma4:e4b

# Auto-start local inference server with app launch (dynamic URL assignment)
UNSLOTH_AUTOSTART=1
UNSLOTH_AUTOSTART_OVERRIDE_BASE_URL=0
UNSLOTH_SERVER_HOST=127.0.0.1
UNSLOTH_SERVER_PORT=
UNSLOTH_SERVER_START_TIMEOUT=45

# Command template used to start your local OpenAI-compatible server.
# {host} and {port} are replaced dynamically at launch.
# Examples:
# UNSLOTH_SERVER_COMMAND=unsloth serve --host {host} --port {port}
# UNSLOTH_SERVER_COMMAND=python -m llama_cpp.server --host {host} --port {port}
# UNSLOTH_SERVER_COMMAND=ollama serve
# UNSLOTH_SERVER_COMMAND=C:\path\to\Ollama\ollama.exe serve
# If left empty, the app auto-detects and tries installed backends (unsloth, llama_cpp, ollama).
UNSLOTH_SERVER_COMMAND=
